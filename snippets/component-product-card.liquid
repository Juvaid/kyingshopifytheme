{% comment %}
  PRODUCT CARD COMPONENT

  Design Reference: docs/03-component-specs.md > Component 2: Product Card

  Params:
  - product (required): Shopify product object
  - show_rating: true/false (default: true)
  - show_quick_add: true/false (default: true)

  Usage:
  {% render 'component-product-card', product: product, show_rating: true, show_quick_add: true %}
{% endcomment %}

<article class="product-card {% if is_compact %}product-card--compact{% endif %}">
  {%- if product.compare_at_price > product.price -%}
    {%- assign savings = product.compare_at_price
      | minus: product.price
      | times: 100.0
      | divided_by: product.compare_at_price
      | round
    -%}
    <div
      class="product-card__badge"
      style="background-color: {{ settings.discount_badge_color | default: 'g#131313ff' }};"
    >
      SAVE {{ savings }}%
    </div>
  {%- endif -%}

  <a href="{{ product.url | default: '#' }}" class="product-card__link" aria-label="{{ product.title | escape }}">
    <span class="visually-hidden">{{ product.title }}</span>
  </a>

  {%- if product.featured_image -%}
    <div class="product-card__image-wrapper">
      <img
        class="product-card__image product-card__image--primary"
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape }}"
        loading="lazy"
        width="600"
        height="600"
      >

      {%- if product.images.size > 1 -%}
        <img
          class="product-card__image product-card__image--secondary"
          src="{{ product.images[1] | image_url: width: 600 }}"
          alt="{{ product.images[1].alt | escape }}"
          loading="lazy"
          width="600"
          height="600"
        >
      {%- endif -%}

      {%- if product.metafields.reviews.rating.value and settings.show_card_rating and settings.card_rating_location == 'on_image' -%}
        <div class="product-card__rating-badge">
          ⭐ {{ product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value | round: 1 }}
        </div>
      {%- endif -%}
    </div>
  {%- elsif placeholder_image -%}
    <div class="product-card__image-wrapper">
      {{ placeholder_image | placeholder_svg_tag: 'product-card__image' }}
    </div>
  {%- endif -%}

  <div class="product-card__content">
    {%- capture rating_html -%}
      {%- if product.metafields.reviews.rating.value and settings.show_card_rating -%}
        <div class="product-card__rating product-card__rating--{{ settings.card_rating_location }}">
          <span class="product-card__rating-stars">⭐</span>
          <span class="product-card__rating-value">
            {{ product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value | round: 1 }}
          </span>
          {%- if product.metafields.reviews.rating_count -%}
            <span class="product-card__rating-count">({{ product.metafields.reviews.rating_count }})</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endcapture -%}

    <div class="product-card__meta">
      {%- if settings.card_rating_location == 'above_title' -%}
        {{ rating_html }}
      {%- endif -%}
      <h3 class="product-card__title">
        {%- if product -%}
          {{ product.title }}
        {%- else -%}
          {{ 'onboarding.product_title' | t }}
        {%- endif -%}
      </h3>
      {%- if settings.card_rating_location == 'below_title' -%}
        {{ rating_html }}
      {%- endif -%}
    </div>

    <div class="product-card__footer">
      <div class="product-card__pricing">
        {%- if product -%}
          <span class="product-card__price">
            {{ product.price | money }}
          </span>
          {%- if settings.card_rating_location == 'below_price' -%}
            {{ rating_html }}
          {%- endif -%}
        {%- else -%}
          <span class="product-card__price">{{ 1999 | money }}</span>
        {%- endif -%}
      </div>
      {%- if show_quick_add -%}
        <div class="product-card__cta">
          {%- assign product_form_id = 'quick-add-' | append: section_id | append: product.id -%}
          <product-form data-section-id="{{ section_id }}">
            {%- form 'product',
              product,
              id: product_form_id,
              class: 'form',
              novalidate: 'novalidate',
              data-type: 'add-to-cart-form'
            -%}
              <input
                type="hidden"
                name="id"
                value="{{ product.selected_or_first_available_variant.id }}"
                class="product-variant-id"
                {% if product.selected_or_first_available_variant.available == false %}
                  disabled
                {% endif %}
              >
              <button
                id="{{ product_form_id }}-submit"
                type="submit"
                name="add"
                class="btn-quick-add"
                aria-haspopup="dialog"
                aria-live="polite"
                data-sold-out-message="true"
                {% if product.selected_or_first_available_variant.available == false %}
                  disabled
                {% endif %}
              >
                <span>
                  {%- if is_compact -%}
                    {%- if product.selected_or_first_available_variant.available -%}
                      Add +
                    {%- else -%}
                      Sold Out
                    {%- endif -%}
                  {%- else -%}
                    {%- if product.selected_or_first_available_variant.available -%}
                      Quick Add
                    {%- else -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- endif -%}
                  {%- endif -%}
                </span>
                <div class="loading-dots" aria-hidden="true">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="dot"></span>
                </div>
              </button>
            {%- endform -%}
          </product-form>
        </div>
      {%- endif -%}
    </div>
  </div>
</article>

{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
