{% comment %}
  Quick Add Toast Notification
  
  Renders a slide-up toast notification when a product is added to cart via Quick Add.
  This is a global element rendered once in theme.liquid.
  
  Settings supported:
  - quick_add_toast_duration: auto-dismiss duration (ms)
  - quick_add_toast_position: bottom-left, bottom-center, bottom-right
{% endcomment %}

<div id="quick-add-toast" class="quick-add-toast" role="alertdialog" aria-modal="false" aria-live="polite" aria-label="{{ 'general.cart.item_added' | t }}" hidden>
  <div class="quick-add-toast__inner">
    <div class="quick-add-toast__product">
      <div class="quick-add-toast__image-wrap">
        <img id="quick-add-toast-image" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="" width="60" height="60" loading="lazy">
      </div>
      <div class="quick-add-toast__info">
        <p class="quick-add-toast__label">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Added to cart
        </p>
        <p class="quick-add-toast__product-title" id="quick-add-toast-title"></p>
        <p class="quick-add-toast__product-price" id="quick-add-toast-price"></p>
      </div>
      <button type="button" class="quick-add-toast__close" id="quick-add-toast-close" aria-label="{{ 'accessibility.close' | t }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="quick-add-toast__actions">
      <button type="button" class="quick-add-toast__action quick-add-toast__action--secondary" id="quick-add-toast-continue">
        {{ settings.quick_add_toast_continue_text | default: 'Continue Shopping' }}
      </button>
      <a href="{{ routes.cart_url }}" class="quick-add-toast__action quick-add-toast__action--primary" id="quick-add-toast-checkout">
        {{ settings.quick_add_toast_view_cart_text | default: 'View Cart' }}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <div class="quick-add-toast__progress" id="quick-add-toast-progress"></div>
  </div>
</div>

<script>
  window.QuickAddToastSettings = {
    duration: {{ settings.quick_add_toast_duration | default: 5000 }},
    position: '{{ settings.quick_add_toast_position | default: "bottom-right" }}',
    continueShopping: '{{ settings.quick_add_toast_continue_text | default: "Continue Shopping" }}'
  };
</script>

<style>
  :root {
    --toast-duration: {{ settings.quick_add_toast_duration | default: 5000 }}ms;
  }

  .quick-add-toast {
    position: fixed;
    z-index: 9999;
    bottom: 2rem;
    {%- if settings.quick_add_toast_position == 'bottom-left' -%}
      left: 1.5rem;
      right: auto;
    {%- elsif settings.quick_add_toast_position == 'bottom-center' -%}
      left: 50%;
      transform: translateX(-50%);
    {%- else -%}
      right: 1.5rem;
      left: auto;
    {%- endif -%}
    width: min(420px, calc(100vw - 3rem));
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.14), 0 2px 8px rgba(0,0,0,0.08);
    overflow: hidden;
    font-family: var(--font-body-family, sans-serif);
    transition: transform 0.42s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
    transform: translateY(120%) scale(0.96);
    opacity: 0;
    pointer-events: none;
  }

  .quick-add-toast.is-visible {
    transform: translateY(0) scale(1);
    opacity: 1;
    pointer-events: all;
  }

  .quick-add-toast__inner {
    position: relative;
    overflow: hidden;
  }

  .quick-add-toast__product {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 16px 12px;
  }

  .quick-add-toast__image-wrap {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 10px;
    overflow: hidden;
    background: #f5f5f5;
  }

  .quick-add-toast__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .quick-add-toast__info {
    flex: 1;
    min-width: 0;
  }

  .quick-add-toast__label {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #16a34a;
    margin: 0 0 3px;
  }

  .quick-add-toast__product-title {
    font-size: 13px;
    font-weight: 600;
    color: #111;
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .quick-add-toast__product-price {
    font-size: 13px;
    font-weight: 500;
    color: #555;
    margin: 0;
  }

  .quick-add-toast__close {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: #aaa;
    padding: 4px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, background 0.2s;
    align-self: flex-start;
    margin-top: -4px;
    margin-right: -4px;
  }

  .quick-add-toast__close:hover {
    color: #111;
    background: #f3f3f3;
  }

  .quick-add-toast__actions {
    display: flex;
    gap: 8px;
    padding: 0 16px 16px;
  }

  .quick-add-toast__action {
    flex: 1;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: none;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .quick-add-toast__action--secondary {
    background: #f3f3f3;
    color: #111;
  }

  .quick-add-toast__action--secondary:hover {
    background: #e5e5e5;
  }

  .quick-add-toast__action--primary {
    background: #111;
    color: #fff;
  }

  .quick-add-toast__action--primary:hover {
    background: #333;
    transform: scale(1.01);
  }

  .quick-add-toast__progress {
    height: 3px;
    background: #111;
    transform-origin: left;
    transform: scaleX(1);
    transition: transform var(--toast-duration) linear;
  }

  .quick-add-toast__progress.is-running {
    transform: scaleX(0);
  }

  @media (max-width: 480px) {
    .quick-add-toast {
      bottom: 1rem;
      left: 1rem !important;
      right: 1rem !important;
      transform: none !important;
      width: auto;
      transform: translateY(120%) !important;
    }

    .quick-add-toast.is-visible {
      transform: translateY(0) !important;
    }
  }
</style>
