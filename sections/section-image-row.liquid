{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .image-row-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: {{ section.settings.gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .image-row-{{ section.id }} {
      grid-template-columns: repeat({{ section.blocks.size | default: 1 }}, 1fr);
      gap: {{ section.settings.gap_desktop }}px;
    }
  }

  .image-row__item {
    position: relative;
    overflow: hidden;
    display: block;
    aspect-ratio: {{ section.settings.image_ratio_desktop }};
  }

  .image-row__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  {%- if section.settings.hover_effect == 'zoom' -%}
    .image-row__item:hover img {
      transform: scale(1.08);
    }
  {%- endif -%}

  @media screen and (max-width: 749px) {
    .image-row__item {
      aspect-ratio: {{ section.settings.image_ratio_mobile }};
    }
  }

  .image-row-header-{{ section.id }} {
    margin-bottom: 40px;
    text-align: {{ section.settings.header_alignment }};
  }

  .image-row-header-{{ section.id }} .description {
    max-width: 700px;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
    {% if section.settings.header_alignment == 'center' %}margin-left: auto; margin-right: auto;{% elsif section.settings.header_alignment == 'right' %}margin-left: auto;{% endif %}
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient isolate">
  <div class="section-{{ section.id }}-padding {% unless section.settings.full_width %}page-width{% endunless %}">
    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="image-row-header-{{ section.id }} {% if section.settings.full_width %}page-width{% endif %}">
        {%- if section.settings.title != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="image-row-{{ section.id }}">
      {%- for block in section.blocks -%}
        <a 
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          class="image-row__item" 
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag: 
              loading: 'lazy', 
              alt: block.settings.image.alt | default: 'Image Row Item',
              class: 'image-row__img' 
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Multi-Image Row",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Header Alignment"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "Full Width"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Desktop Gap",
      "default": 0
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Mobile Gap",
      "default": 0
    },
    {
      "type": "header",
      "content": "Image Styling"
    },
    {
      "type": "select",
      "id": "image_ratio_desktop",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "16 / 9", "label": "Wide (16:9)" },
        { "value": "21 / 9", "label": "Ultra Wide (21:9)" }
      ],
      "default": "4 / 3",
      "label": "Aspect Ratio (Desktop)"
    },
    {
      "type": "select",
      "id": "image_ratio_mobile",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" }
      ],
      "default": "1 / 1",
      "label": "Aspect Ratio (Mobile)"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1",
      "label": "Mobile Columns"
    },
    {
      "type": "select",
      "id": "hover_effect",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "zoom", "label": "Zoom Image" }
      ],
      "default": "zoom",
      "label": "Hover Effect"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi-Image Row",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
