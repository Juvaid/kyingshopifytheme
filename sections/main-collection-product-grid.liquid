{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    --card-border-radius: {{ section.settings.card_border_radius }}px;
    --card-image-padding: {{ section.settings.card_image_padding }}px;
    --card-title-lines: {{ section.settings.card_title_lines }};
    --grid-gap-h: {{ section.settings.grid_gap_horizontal }}px;
    --grid-gap-v: {{ section.settings.grid_gap_vertical }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Grid Gap Overrides */
  .section-{{ section.id }}-padding #product-grid {
    column-gap: var(--grid-gap-h, 16px);
    row-gap: var(--grid-gap-v, 24px);
  }

  /* Grid Banner Slideshow Styles */
  .grid-banner-slideshow-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.grid_banner_radius }}px;
    margin-bottom: {{ section.settings.grid_banner_margin_bottom }}px;
    background: #f3f3f3;
  }

  .grid-banner-wrapper-{{ section.id }} {
    width: 100%;
    {%- if section.settings.grid_banner_height_mode == 'adapt' -%}
      {%- if section.blocks.first.settings.image != blank -%}
        aspect-ratio: {{ section.blocks.first.settings.image.aspect_ratio }};
      {%- else -%}
        height: 400px;
      {%- endif -%}

      {%- if section.blocks.first.settings.mobile_image != blank -%}
        @media screen and (max-width: 749px) {
          aspect-ratio: {{ section.blocks.first.settings.mobile_image.aspect_ratio }};
        }
      {%- endif -%}
    {%- else -%}
      height: {{ section.settings.grid_banner_height_mobile }}px;
    {%- endif -%}

    {%- if section.settings.grid_banner_transition == 'fade' -%}
      display: block;
      position: relative;
    {%- else -%}
      display: flex;
      transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    {%- endif -%}
  }

  @media screen and (min-width: 750px) {
    .grid-banner-wrapper-{{ section.id }} {
      {%- if section.settings.grid_banner_height_mode == 'fixed' -%}
        height: {{ section.settings.grid_banner_height_desktop }}px;
      {%- endif -%}
    }
  }

  /* Slide rules */
  {%- if section.settings.grid_banner_transition == 'fade' -%}
    .grid-banner-slide-{{ section.id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.8s ease-in-out;
      z-index: 1;
      overflow: hidden;
    }
    .grid-banner-slide-{{ section.id }}.active {
      opacity: 1;
      z-index: 2;
    }
  {%- else -%}
    .grid-banner-slide-{{ section.id }} {
      flex: 0 0 100%;
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }
  {%- endif -%}

  .grid-banner-link-{{ section.id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .grid-banner-link-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Text Overlay */
  .grid-banner-text-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 90%;
    z-index: 3;
    pointer-events: none;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }
  .grid-banner-text-{{ section.id }} h2 { 
    margin: 0 0 1rem; color: inherit; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.01em; 
  }
  .grid-banner-text-{{ section.id }} p { 
    margin: 0; color: inherit; font-size: 1.4rem; 
  }
  @media screen and (min-width: 750px) {
    .grid-banner-text-{{ section.id }} h2 { font-size: 4rem; letter-spacing: -0.02em; }
    .grid-banner-text-{{ section.id }} p { font-size: 1.8rem; }
  }

  .grid-banner-nav-{{ section.id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.4);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.3s;
  }
  .grid-banner-nav-{{ section.id }}:hover { background: rgba(255,255,255,0.6); }
  .grid-banner-nav-{{ section.id }} svg { width: 20px; height: 20px; fill: #000; }
  .grid-banner-prev-{{ section.id }} { left: 15px; }
  .grid-banner-next-{{ section.id }} { right: 15px; }

  .grid-banner-dots-{{ section.id }} {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }
  .grid-banner-dot-{{ section.id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0,0,0,0.2);
    border: 1px solid #fff;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .grid-banner-dot-{{ section.id }}.active {
    background: #000;
    transform: scale(1.2);
  }

  img.desktop-only-{{ section.id }} { display: block; }
  img.mobile-only-{{ section.id }} { display: none; }

  @media screen and (max-width: 749px) {
    img.desktop-only-{{ section.id }} { display: none; }
    img.mobile-only-{{ section.id }} { display: block; }
  }

  @media screen and (min-width: 750px) {
    .product-grid .grid__item--featured {
      grid-column: span 2;
    }
    .product-grid .grid__item--featured .card-wrapper {
      height: 100%;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by 240 -%}
    {%- if section.blocks.size > 0 -%}
      <div class="page-width">
        <div class="grid-banner-slideshow-{{ section.id }}" id="GridBanner-{{ section.id }}">
          <div class="grid-banner-wrapper-{{ section.id }}" id="GridBannerWrapper-{{ section.id }}">
            {%- for block in section.blocks -%}
              <div class="grid-banner-slide-{{ section.id }}{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link | default: '#' }}" class="grid-banner-link-{{ section.id }}">
                  {%- if block.settings.image != blank or block.settings.mobile_image != blank -%}
                    {%- liquid
                      assign mobile_image = block.settings.mobile_image | default: block.settings.image
                      assign desktop_image = block.settings.image | default: block.settings.mobile_image
                      assign loading_attr = 'lazy'
                      assign fetch_priority = 'auto'
                      if forloop.first
                        assign loading_attr = 'eager'
                        assign fetch_priority = 'high'
                      endif
                    -%}
                    <img 
                      srcset="{%- if desktop_image.width >= 375 -%}{{ desktop_image | image_url: width: 375 }} 375w,{%- endif -%}
                        {%- if desktop_image.width >= 550 -%}{{ desktop_image | image_url: width: 550 }} 550w,{%- endif -%}
                        {%- if desktop_image.width >= 750 -%}{{ desktop_image | image_url: width: 750 }} 750w,{%- endif -%}
                        {%- if desktop_image.width >= 1100 -%}{{ desktop_image | image_url: width: 1100 }} 1100w,{%- endif -%}
                        {%- if desktop_image.width >= 1500 -%}{{ desktop_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                        {%- if desktop_image.width >= 1780 -%}{{ desktop_image | image_url: width: 1780 }} 1780w,{%- endif -%}
                        {%- if desktop_image.width >= 2000 -%}{{ desktop_image | image_url: width: 2000 }} 2000w,{%- endif -%}
                        {{ desktop_image | image_url }} {{ desktop_image.width }}w"
                      src="{{ desktop_image | image_url: width: 1500 }}" 
                      sizes="(min-width: 1400px) 1400px, 100vw"
                      alt="{{ desktop_image.alt | escape }}" 
                      class="desktop-only-{{ section.id }}" 
                      loading="{{ loading_attr }}"
                      fetchpriority="{{ fetch_priority }}"
                      width="{{ desktop_image.width | default: 2000 }}" 
                      height="{{ desktop_image.height | default: 1000 }}"
                    >
                    <img 
                      srcset="{%- if mobile_image.width >= 375 -%}{{ mobile_image | image_url: width: 375 }} 375w,{%- endif -%}
                        {%- if mobile_image.width >= 550 -%}{{ mobile_image | image_url: width: 550 }} 550w,{%- endif -%}
                        {%- if mobile_image.width >= 750 -%}{{ mobile_image | image_url: width: 750 }} 750w,{%- endif -%}
                        {{ mobile_image | image_url }} {{ mobile_image.width }}w"
                      src="{{ mobile_image | image_url: width: 750 }}" 
                      sizes="100vw"
                      alt="{{ mobile_image.alt | escape }}" 
                      class="mobile-only-{{ section.id }}" 
                      loading="{{ loading_attr }}"
                      fetchpriority="{{ fetch_priority }}"
                      width="{{ mobile_image.width | default: 1000 }}" 
                      height="{{ mobile_image.height | default: 1200 }}"
                    >
                  {%- else -%}
                    {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}

                  {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
                    <div class="grid-banner-text-{{ section.id }}" style="color: {{ block.settings.text_color }};">
                      {%- if block.settings.heading != blank -%}
                        <h2 class="h1">{{ block.settings.heading }}</h2>
                      {%- endif -%}
                      {%- if block.settings.subheading != blank -%}
                        <p class="h3">{{ block.settings.subheading }}</p>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </a>
              </div>
            {%- endfor -%}
          </div>

          {%- if section.blocks.size > 1 -%}
            <button class="grid-banner-nav-{{ section.id }} grid-banner-prev-{{ section.id }}" onclick="moveGridSlide{{ section.id | replace: '-', '_' }}( -1)">
              <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </button>
            <button class="grid-banner-nav-{{ section.id }} grid-banner-next-{{ section.id }}" onclick="moveGridSlide{{ section.id | replace: '-', '_' }}( 1)">
              <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
            </button>

            <div class="grid-banner-dots-{{ section.id }}">
              {%- for block in section.blocks -%}
                <button class="grid-banner-dot-{{ section.id }}{% if forloop.first %} active{% endif %}" onclick="goToGridSlide{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      <script>
        (function() {
          const wrapper = document.getElementById('GridBannerWrapper-{{ section.id }}');
          const dots = document.querySelectorAll('.grid-banner-dot-{{ section.id }}');
          let currentSlide = 0;
          const totalSlides = {{ section.blocks.size }};
          const autoplaySpeed = {{ section.settings.grid_banner_autoplay_speed | times: 1000 }};
          let autoPlayInterval;

          const transitionType = "{{ section.settings.grid_banner_transition }}";
          const slides = document.querySelectorAll('.grid-banner-slide-{{ section.id }}');

          window.moveGridSlide{{ section.id | replace: '-', '_' }} = function(direction) {
            currentSlide = (currentSlide + direction + totalSlides) % totalSlides;
            updateSlideshow();
            resetInterval();
          };

          window.goToGridSlide{{ section.id | replace: '-', '_' }} = function(index) {
            currentSlide = index;
            updateSlideshow();
            resetInterval();
          };

          function updateSlideshow() {
            if (transitionType === 'slide') {
              wrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
            } else {
              slides.forEach((slide, index) => {
                slide.classList.toggle('active', index === currentSlide);
              });
            }
            dots.forEach((dot, index) => {
              dot.classList.toggle('active', index === currentSlide);
            });
          }

          function startAutoPlay() {
            if ({{ section.settings.grid_banner_autoplay }} && totalSlides > 1) {
              autoPlayInterval = setInterval(() => moveGridSlide{{ section.id | replace: '-', '_' }}(1), autoplaySpeed);
            }
          }

          function resetInterval() {
            clearInterval(autoPlayInterval);
            startAutoPlay();
          }

          // Performance: Only autoplay when in view
          if ('IntersectionObserver' in window) {
            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  startAutoPlay();
                } else {
                  clearInterval(autoPlayInterval);
                }
              });
            }, { threshold: 0.1 });
            observer.observe(document.getElementById('GridBanner-{{ section.id }}'));
          } else {
            startAutoPlay();
          }

          // Touch Swipe Support
          let touchStartX = 0;
          let touchEndX = 0;
          wrapper.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
          wrapper.addEventListener('touchend', e => {
            touchEndX = e.changedTouches[0].screenX;
            if (touchStartX - touchEndX > 50) moveGridSlide{{ section.id | replace: '-', '_' }}(1);
            if (touchEndX - touchStartX > 50) moveGridSlide{{ section.id | replace: '-', '_' }}(-1);
          }, { passive: true });
        })();
      </script>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'price-range-slider.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate,
            enable_price_slider: section.settings.enable_price_slider,
            expand_filters: section.settings.expand_filters,
            filter_header_style: section.settings.filter_header_style,
            swatch_shape: section.settings.swatch_shape
          %}
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              {%- if section.settings.empty_collection_image != blank -%}
                <div class="collection-empty__image" style="max-width: 300px; margin: 0 auto 2rem;">
                  <img
                    src="{{ section.settings.empty_collection_image | image_url: width: 600 }}"
                    alt="{{ section.settings.empty_collection_heading | default: 'No products found' | escape }}"
                    loading="lazy"
                    width="600"
                    style="width: 100%; height: auto;"
                  >
                </div>
              {%- endif -%}
              <h2 class="title title--primary">
                {%- if section.settings.empty_collection_heading != blank -%}
                  {{ section.settings.empty_collection_heading }}
                {%- else -%}
                  {{ 'sections.collection_template.empty' | t -}}
                {%- endif -%}
                <br>
                {%- if section.settings.empty_collection_text != blank -%}
                  {{ section.settings.empty_collection_text }}
                {%- else -%}
                  {{
                    'sections.collection_template.use_fewer_filters_html'
                    | t: link: collection.url, class: 'underlined-link link'
                  }}
                {%- endif -%}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div
            class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          >
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                grid--{{ section.settings.columns_desktop }}-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {%- for product in collection.products -%}
                {%- assign is_featured = false -%}
                {%- if section.settings.make_first_product_featured and forloop.first -%}
                  {%- assign is_featured = true -%}
                {%- endif -%}
                <li
                  class="grid__item{% if is_featured %} grid__item--featured{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'component-product-card',
                    product: product,
                    show_rating: section.settings.show_rating,
                    show_quick_add: true,
                    show_compare_at_price: section.settings.show_compare_at_price,
                    show_product_type: section.settings.show_product_type,
                    show_variant_count: section.settings.show_variant_count,
                    card_title_lines: section.settings.card_title_lines,
                    card_hover_effect: section.settings.card_hover_effect,
                    card_content_alignment: section.settings.card_content_alignment,
                    card_image_padding: section.settings.card_image_padding,
                    show_sale_badge: section.settings.show_sale_badge,
                    sale_badge_style: section.settings.sale_badge_style,
                    badge_position: section.settings.badge_position,
                    card_border_radius: section.settings.card_border_radius
                  %}
                </li>
              {%- endfor -%}
            </ul>

            {%- if section.settings.enable_infinite_scroll -%}
              {%- if paginate.pages > 1 and paginate.next -%}
                <div class="collection-load-more" id="CollectionLoadMore-{{ section.id }}" style="text-align: center; margin: 3rem 0 1rem;">
                  <button
                    type="button"
                    class="button button--secondary collection-load-more__button"
                    data-next-url="{{ paginate.next.url }}"
                    id="LoadMoreBtn-{{ section.id }}"
                  >
                    Load More Products
                  </button>
                </div>
                <script>
                  (function() {
                    const btn = document.getElementById('LoadMoreBtn-{{ section.id }}');
                    if (!btn) return;
                    btn.addEventListener('click', async function() {
                      const url = btn.getAttribute('data-next-url');
                      if (!url) return;
                      btn.textContent = 'Loading...';
                      btn.disabled = true;
                      try {
                        const res = await fetch(url);
                        const html = await res.text();
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const newItems = doc.querySelectorAll('#product-grid > li');
                        const grid = document.getElementById('product-grid');
                        newItems.forEach(item => grid.appendChild(item.cloneNode(true)));
                        const newBtn = doc.querySelector('#LoadMoreBtn-{{ section.id }}');
                        if (newBtn) {
                          btn.setAttribute('data-next-url', newBtn.getAttribute('data-next-url'));
                          btn.textContent = 'Load More Products';
                          btn.disabled = false;
                        } else {
                          btn.closest('.collection-load-more').remove();
                        }
                      } catch (e) {
                        btn.textContent = 'Load More Products';
                        btn.disabled = false;
                      }
                    });
                  })();
                </script>
              {%- endif -%}
            {%- else -%}
              {%- if paginate.pages > 1 -%}
                {% render 'pagination', paginate: paginate, anchor: '' %}
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_first_product_featured",
      "default": false,
      "label": "Make first product featured (Spans 2 columns)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
