{{ 'component-video-banner.css' | asset_url | stylesheet_tag }}
{%- style -%}
  .slideshow-{{ section.id }} {
    position: relative;
    z-index: 1; /* Establishes a stacking context to prevent z-index leaks over the header/menu */
    width: 100%;
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px auto;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    {%- unless section.settings.full_width -%}
      max-width: 1400px; /* Standard theme page width */
    {%- endunless -%}
  }

  .slideshow-wrapper-{{ section.id }} {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    width: 100%;
    will-change: transform;
    {%- if section.settings.slideshow_height == 'adapt' -%}
      {%- if section.blocks.first.settings.image != blank -%}
        aspect-ratio: {{ section.blocks.first.settings.image.aspect_ratio }};
      {%- else -%}
        height: 500px;
      {%- endif -%}

      {%- if section.blocks.first.settings.mobile_image != blank -%}
        @media screen and (max-width: 768px) {
          aspect-ratio: {{ section.blocks.first.settings.mobile_image.aspect_ratio }};
        }
      {%- endif -%}
    {%- elsif section.settings.slideshow_height == 'small' -%}
      height: 400px;
    {%- elsif section.settings.slideshow_height == 'medium' -%}
      height: 550px;
    {%- elsif section.settings.slideshow_height == 'large' -%}
      height: 700px;
    {%- endif -%}
  }

  .slideshow-{{ section.id }}:not(.slideshow--full-width) {
    max-width: var(--page-width);
    margin: 0 auto;
    overflow: hidden;
  }

  .slide-{{ section.id }} {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .slide-{{ section.id }} a {
     display: block;
     width: 100%;
     height: 100%;
  }

  .slide-{{ section.id }} img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  /* Robust Responsive Hiding */
  @media screen and (min-width: 769px) {
    .mobile-only-{{ section.id }} { display: none !important; }
    .desktop-only-{{ section.id }} { display: block !important; }
  }
  @media screen and (max-width: 768px) {
    .desktop-only-{{ section.id }} { display: none !important; }
    .mobile-only-{{ section.id }} { display: block !important; }
    .slideshow-wrapper-{{ section.id }} {
      {%- if section.settings.slideshow_height != 'adapt' -%}
        height: 450px; /* Fixed mobile height if not adapt */
      {%- endif -%}
    }
  }

  /* Navigation Arrows */
  .slide-nav-{{ section.id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    background: rgba(255,255,255,0.3);
    backdrop-filter: blur(5px);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: {%- if section.settings.show_arrows -%}flex{%- else -%}none{%- endif -%};
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background 0.3s;
  }
  .slide-nav-{{ section.id }}:hover { background: rgba(255,255,255,0.5); }
  .slide-nav-{{ section.id }} svg { width: calc({{ section.settings.arrow_size }}px * 0.5); height: calc({{ section.settings.arrow_size }}px * 0.5); fill: #000; }
  .slide-prev-{{ section.id }} { left: 20px; }
  .slide-next-{{ section.id }} { right: 20px; }

  /* Dots */
  .slide-dots-{{ section.id }} {
    position: absolute;
    bottom: 20px;
    {%- if section.settings.dots_alignment == 'left' -%}
      left: 20px;
      transform: none;
    {%- elsif section.settings.dots_alignment == 'right' -%}
      right: 20px;
      transform: none;
    {%- else -%}
      left: 50%;
      transform: translateX(-50%);
    {%- endif -%}
    display: {%- if section.settings.show_dots -%}flex{%- else -%}none{%- endif -%};
    gap: 10px;
    z-index: 2;
    opacity: {{ section.settings.dots_opacity | divided_by: 100.0 }};
  }
  .slide-dot-{{ section.id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(0,0,0,0.2);
    border: 1px solid #fff;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .slide-dot-{{ section.id }}.active {
    background: #000;
    transform: scale(1.2);
  }

  @media (max-width: 768px) {
    .slide-nav-{{ section.id }} { width: 40px; height: 40px; }
    .slide-prev-{{ section.id }} { left: 10px; }
    .slide-next-{{ section.id }} { right: 10px; }
  }
{%- endstyle -%}

<div class="slideshow-{{ section.id }}" id="Slideshow-{{ section.id }}">
  <div class="slideshow-wrapper-{{ section.id }}" id="SlideshowWrapper-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- liquid
        assign is_video = false
        if block.settings.video_file_url != blank
          assign is_video = true
        endif
      -%}
      <div class="slide-{{ section.id }} slide-item-{{ section.id }}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        {%- if is_video -%}
          <div class="video-portal-wrapper aspect-{{ block.settings.aspect_ratio }}">
            {%- if block.settings.aspect_ratio != 'full' and block.settings.video_file_url != blank -%}
              <video class="video-bg-blur" muted loop playsinline autoplay>
                <source src="{{ block.settings.video_file_url }}" type="video/mp4">
              </video>
            {%- endif -%}

            <div class="video-portal-content origin-{{ block.settings.shrink_origin | default: 'center' }}" 
                 id="Portal-{{ section.id }}-{{ forloop.index0 }}"
                 data-shrink-delay="{{ block.settings.shrink_delay | default: 2.5 | times: 1000 }}"
                 data-scale-back="{{ block.settings.enable_scale_back | default: false }}"
                 data-scale-back-delay="{{ block.settings.scale_back_delay | default: 12 | times: 1000 }}"
            >
              <video 
                id="Video-{{ section.id }}-{{ forloop.index0 }}"
                muted 
                playsinline 
              >
                <source src="{{ block.settings.video_file_url }}" type="video/mp4">
              </video>

              {% comment %} Primary Banner Cover (Visible before / after shrink) {% endcomment %}
              {%- if block.settings.image != blank -%}
                <div class="video-portal-cover">
                   {%- liquid
                     assign mobile_image = block.settings.mobile_image | default: block.settings.image
                     assign loading_attr = 'lazy'
                     assign fetch_priority = 'auto'
                     if forloop.first
                       assign loading_attr = 'eager'
                       assign fetch_priority = 'high'
                     endif
                   -%}
                   <img 
                     srcset="{%- if block.settings.image.width >= 375 -%}{{ block.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
                       {%- if block.settings.image.width >= 550 -%}{{ block.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
                       {%- if block.settings.image.width >= 750 -%}{{ block.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
                       {%- if block.settings.image.width >= 1100 -%}{{ block.settings.image | image_url: width: 1100 }} 1100w,{%- endif -%}
                       {%- if block.settings.image.width >= 1500 -%}{{ block.settings.image | image_url: width: 1500 }} 1500w,{%- endif -%}
                       {%- if block.settings.image.width >= 1780 -%}{{ block.settings.image | image_url: width: 1780 }} 1780w,{%- endif -%}
                       {%- if block.settings.image.width >= 2000 -%}{{ block.settings.image | image_url: width: 2000 }} 2000w,{%- endif -%}
                       {%- if block.settings.image.width >= 3000 -%}{{ block.settings.image | image_url: width: 3000 }} 3000w,{%- endif -%}
                       {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
                     src="{{ block.settings.image | image_url: width: 1500 }}"
                     sizes="100vw"
                     alt="{{ block.settings.image.alt | escape }}" 
                     class="portal-cover-desktop" 
                     loading="{{ loading_attr }}"
                     fetchpriority="{{ fetch_priority }}"
                     width="{{ block.settings.image.width }}" 
                     height="{{ block.settings.image.height }}"
                   >
                   {%- if block.settings.mobile_image != blank -%}
                     <img 
                       srcset="{%- if mobile_image.width >= 375 -%}{{ mobile_image | image_url: width: 375 }} 375w,{%- endif -%}
                         {%- if mobile_image.width >= 550 -%}{{ mobile_image | image_url: width: 550 }} 550w,{%- endif -%}
                         {%- if mobile_image.width >= 750 -%}{{ mobile_image | image_url: width: 750 }} 750w,{%- endif -%}
                         {{ mobile_image | image_url }} {{ mobile_image.width }}w"
                       src="{{ mobile_image | image_url: width: 750 }}"
                       sizes="100vw"
                       alt="{{ mobile_image.alt | escape }}" 
                       class="portal-cover-mobile" 
                       loading="{{ loading_attr }}"
                       fetchpriority="{{ fetch_priority }}"
                       width="{{ mobile_image.width }}" 
                       height="{{ mobile_image.height }}"
                     >
                   {%- endif -%}
                </div>
              {%- endif -%}

              {% comment %} Product/Collection Tagging {% endcomment %}
              {%- if block.settings.product != blank or block.settings.collection != blank -%}
                <div class="slide-metadata-tag tag-{{ block.settings.tag_position }}" style="transition-delay: {{ block.settings.tag_appearance_delay }}s;">
                  {%- if block.settings.product != blank -%}
                    {%- assign tagged_product = block.settings.product -%}
                    <a href="{{ tagged_product.url }}" class="product-tag-card">
                      <img src="{{ tagged_product.featured_image | image_url: width: 120 }}" alt="{{ tagged_product.title }}" class="product-tag-image" loading="lazy">
                      <div class="product-tag-info">
                        <span class="product-tag-title">{{ tagged_product.title }}</span>
                        {%- if block.settings.show_price -%}
                          <span class="product-tag-price">{{ tagged_product.price | money }}</span>
                        {%- endif -%}
                        <span class="product-tag-cta">{{ block.settings.cta_button_text | default: 'Buy Now' }}</span>
                      </div>
                    </a>
                  {%- elsif block.settings.collection != blank -%}
                    {%- assign tagged_collection = block.settings.collection -%}
                    <a href="{{ tagged_collection.url }}" class="collection-tag-pill">
                      {{ block.settings.cta_button_text | default: 'Shop' }} {{ tagged_collection.title }} &rarr;
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ block.settings.link | default: '#' }}">
            {%- if block.settings.image != blank -%}
               {%- liquid
                 assign mobile_image = block.settings.mobile_image | default: block.settings.image
                 assign loading_attr = 'lazy'
                 assign fetch_priority = 'auto'
                 if forloop.first
                   assign loading_attr = 'eager'
                   assign fetch_priority = 'high'
                 endif
               -%}
               <img 
                 srcset="{%- if block.settings.image.width >= 375 -%}{{ block.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
                   {%- if block.settings.image.width >= 550 -%}{{ block.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
                   {%- if block.settings.image.width >= 750 -%}{{ block.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
                   {%- if block.settings.image.width >= 1100 -%}{{ block.settings.image | image_url: width: 1100 }} 1100w,{%- endif -%}
                   {%- if block.settings.image.width >= 1500 -%}{{ block.settings.image | image_url: width: 1500 }} 1500w,{%- endif -%}
                   {%- if block.settings.image.width >= 1780 -%}{{ block.settings.image | image_url: width: 1780 }} 1780w,{%- endif -%}
                   {%- if block.settings.image.width >= 2000 -%}{{ block.settings.image | image_url: width: 2000 }} 2000w,{%- endif -%}
                   {%- if block.settings.image.width >= 3000 -%}{{ block.settings.image | image_url: width: 3000 }} 3000w,{%- endif -%}
                   {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
                 src="{{ block.settings.image | image_url: width: 1500 }}"
                 sizes="{% if section.settings.full_width %}100vw{% else %}(min-width: 1400px) 1400px, 100vw{% endif %}"
                 alt="{{ block.settings.image.alt | escape }}" 
                 class="desktop-only-{{ section.id }}" 
                 loading="{{ loading_attr }}"
                 fetchpriority="{{ fetch_priority }}"
                 width="{{ block.settings.image.width }}" 
                 height="{{ block.settings.image.height }}"
               >
               <img 
                 srcset="{%- if mobile_image.width >= 375 -%}{{ mobile_image | image_url: width: 375 }} 375w,{%- endif -%}
                   {%- if mobile_image.width >= 550 -%}{{ mobile_image | image_url: width: 550 }} 550w,{%- endif -%}
                   {%- if mobile_image.width >= 750 -%}{{ mobile_image | image_url: width: 750 }} 750w,{%- endif -%}
                   {{ mobile_image | image_url }} {{ mobile_image.width }}w"
                 src="{{ mobile_image | image_url: width: 750 }}"
                 sizes="100vw"
                 alt="{{ mobile_image.alt | escape }}" 
                 class="mobile-only-{{ section.id }}" 
                 loading="{{ loading_attr }}"
                 fetchpriority="{{ fetch_priority }}"
                 width="{{ mobile_image.width }}" 
                 height="{{ mobile_image.height }}"
               >
            {%- else -%}
               <div class="placeholder-svg-wrapper" style="height: 100%; display: flex; align-items: center; background: #f3f3f3;">
                 {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
               </div>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    {%- if section.settings.show_arrows -%}
      <button class="slide-nav-{{ section.id }} slide-prev-{{ section.id }}" onclick="moveSlide{{ section.id | replace: '-', '_' }}(-1)">
        <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      <button class="slide-nav-{{ section.id }} slide-next-{{ section.id }}" onclick="moveSlide{{ section.id | replace: '-', '_' }}(1)">
        <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </button>
    {%- endif -%}

    <div class="slide-dots-{{ section.id }}">
      {%- for block in section.blocks -%}
        <button class="slide-dot-{{ section.id }}{% if forloop.first %} active{% endif %}" onclick="goToSlide{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    let currentSlide = 0;
    const totalSlides = {{ section.blocks.size }};
    const wrapper = document.getElementById('SlideshowWrapper-{{ section.id }}');
    const dots = document.querySelectorAll('.slide-dot-{{ section.id }}');
    const slideItems = document.querySelectorAll('.slide-item-{{ section.id }}');
    let autoPlayInterval;

    function updateSlideshow() {
      if (!wrapper) return;
      wrapper.style.transform = `translate3d(-${currentSlide * 100}%, 0, 0)`;
      
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentSlide);
      });

      // Handle Video Portals and lifecycle
      slideItems.forEach((slide, index) => {
        const portal = slide.querySelector('.video-portal-content');
        const video = slide.querySelector('.video-portal-content video');
        
        // Clear existing timers
        if (slide._portalTimer) clearTimeout(slide._portalTimer);
        
        if (index === currentSlide) {
          if (portal && video) {
            const shrinkDelay = parseInt(portal.dataset.shrinkDelay) || 2500;

            // 1. Initial State: Reset video and ensure image is showing
            video.pause();
            video.currentTime = 0;
            portal.classList.remove('is-active');

            // 2. Add Listener for "One-time" play
            if (!video._hasEndListener) {
              video.addEventListener('ended', () => {
                portal.classList.remove('is-active');
              });
              video._hasEndListener = true;
            }

            // 3. Trigger Shrink Transition
            slide._portalTimer = setTimeout(() => {
               portal.classList.add('is-active');
               
               // 4. Start Video exactly when shrink starts (with slight stagger for smoothness)
               setTimeout(() => {
                 video.play().catch(e => console.log("Playback interrupted:", e));
               }, 300);
            }, shrinkDelay);
          }
        } else {
          // Clean up inactive slides
          if (portal) portal.classList.remove('is-active');
          if (video) {
            video.pause();
            video.currentTime = 0;
          }
        }
      });
    }

    window.moveSlide{{ section.id | replace: '-', '_' }} = function(direction) {
      currentSlide = (currentSlide + direction + totalSlides) % totalSlides;
      updateSlideshow();
      resetInterval();
    };

    window.goToSlide{{ section.id | replace: '-', '_' }} = function(index) {
      currentSlide = index;
      updateSlideshow();
      resetInterval();
    };

    function startAutoPlay() {
      if ({{ section.settings.autoplay }}) {
        autoPlayInterval = setInterval(() => {
          currentSlide = (currentSlide + 1) % totalSlides;
          updateSlideshow();
        }, {{ section.settings.autoplay_speed }} * 1000);
      }
    }

    function resetInterval() {
      clearInterval(autoPlayInterval);
      startAutoPlay();
    }

    // Performance: Only autoplay when in view (Threshold 0.3 as per spec)
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            startAutoPlay();
            updateSlideshow(); // Ensure first slide starts active
          } else {
            clearInterval(autoPlayInterval);
            // Pause all videos when section is out of view
            document.querySelectorAll('.slide-item-{{ section.id }} video').forEach(v => v.pause());
          }
        });
      }, { threshold: 0.3 });
      observer.observe(document.getElementById('Slideshow-{{ section.id }}'));
    } else {
      startAutoPlay();
      updateSlideshow();
    }

    // Touch Swipe Support
    let touchStartX = 0;
    let touchEndX = 0;

    wrapper.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    wrapper.addEventListener('touchend', e => {
      touchEndX = e.changedTouches[0].screenX;
      if (touchStartX - touchEndX > 50) moveSlide{{ section.id | replace: '-', '_' }}(1);
      if (touchEndX - touchStartX > 50) moveSlide{{ section.id | replace: '-', '_' }}(-1);
    }, { passive: true });

  })();
</script>

{% schema %}
{
  "name": "Custom Slideshow",
  "settings": [
    {
      "type": "select",
      "id": "slideshow_height",
      "label": "Slideshow Height",
      "options": [
        { "value": "adapt", "label": "Adapt to First Image" },
        { "value": "small", "label": "Small (400px)" },
        { "value": "medium", "label": "Medium (550px)" },
        { "value": "large", "label": "Large (700px)" }
      ],
      "default": "adapt"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width Display",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay Speed",
      "default": 5
    },
    {
      "type": "header",
      "content": "Navigation Controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "range",
      "id": "arrow_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Arrow Button Size",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Navigation Dots",
      "default": true
    },
    {
      "type": "select",
      "id": "dots_alignment",
      "label": "Dots Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "dots_opacity",
      "min": 10,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Dots Visibility / Opacity",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border Radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Media Configuration"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image (Static)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (Optional)"
        },
        {
          "type": "text",
          "id": "video_file_url",
          "label": "Video File URL",
          "info": "Upload to Content > Files. Use .mp4 for best results."
        },
        {
          "type": "image_picker",
          "id": "video_poster",
          "label": "Video Poster Image",
          "info": "Fallback frame while video loads."
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Video Aspect Ratio",
          "options": [
            { "value": "full", "label": "Full Width/Height" },
            { "value": "16-9", "label": "16:9 Landscape" },
            { "value": "9-16", "label": "9:16 Portrait" },
            { "value": "1-1", "label": "1:1 Square" }
          ],
          "default": "full"
        },
        {
          "type": "header",
          "content": "Transition & Animation"
        },
        {
          "type": "range",
          "id": "shrink_delay",
          "min": 0,
          "max": 5,
          "step": 0.5,
          "unit": "s",
          "label": "Banner Static Duration",
          "info": "How long the banner stays full-screen before shrinking to video.",
          "default": 2.5
        },
        {
          "type": "select",
          "id": "shrink_origin",
          "label": "Shrink Direction (Origin)",
          "options": [
            { "value": "center", "label": "Center" },
            { "value": "top-left", "label": "To Top-Left" },
            { "value": "top-right", "label": "To Top-Right" },
            { "value": "bottom-left", "label": "To Bottom-Left" },
            { "value": "bottom-right", "label": "To Bottom-Right" }
          ],
          "default": "center"
        },
        {
          "type": "header",
          "content": "Tagging & CTA"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Tagged Product"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Tagged Collection"
        },
        {
          "type": "select",
          "id": "tag_position",
          "label": "Tag Position",
