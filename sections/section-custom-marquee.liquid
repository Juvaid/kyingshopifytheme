{%- style -%}
  .oh-marquee-{{ section.id }} {
    background: {{ section.settings.background_color }};
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding: {{ section.settings.padding_vertical }}px 0; 
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    width: 100%;
    z-index: 1;
  }

  .oh-marquee-track-{{ section.id }} {
    display: inline-flex;
    animation: ohMarqueeScroll-{{ section.id }} {{ section.settings.scroll_speed }}s linear infinite;
    min-width: 200%;
    will-change: transform; 
  }

  .oh-marquee-{{ section.id }}:hover .oh-marquee-track-{{ section.id }} {
    animation-play-state: paused;
    cursor: grab;
  }
  
  .oh-marquee-item-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    margin: 0 {{ section.settings.item_margin }}px; 
    padding-right: {{ section.settings.item_margin }}px;
    border-right: 1px solid rgba(0,0,0,0.08);
    user-select: none; 
  }
  .oh-marquee-item-{{ section.id }}:last-child { border-right: none; }

  .oh-marquee-icon-{{ section.id }} {
    width: {{ section.settings.icon_size }}px;  
    height: {{ section.settings.icon_size }}px; 
    margin-right: 16px;
    color: {{ section.settings.text_color }}; 
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .oh-marquee-icon-{{ section.id }} svg,
  .oh-marquee-icon-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .oh-text-group-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: 1.2;
    text-align: left;
  }
  .oh-marquee-text-{{ section.id }} {
    font-size: {{ section.settings.font_size }}px; 
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: {{ section.settings.text_color }};
  }
  .oh-marquee-sub-{{ section.id }} {
    font-size: {{ section.settings.sub_font_size }}px; 
    font-weight: 500;
    color: {{ section.settings.sub_text_color }};
    text-transform: capitalize;
  }

  @keyframes ohMarqueeScroll-{{ section.id }} {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .oh-marquee-item-{{ section.id }} { margin: 0 30px; padding-right: 30px; }
    .oh-marquee-icon-{{ section.id }} { width: 40px; height: 40px; margin-right: 12px; }
    .oh-marquee-text-{{ section.id }} { font-size: 13px; }
    .oh-marquee-sub-{{ section.id }} { font-size: 11px; }
  }
{%- endstyle -%}

<div class="oh-marquee-{{ section.id }} marquee-section" data-section-id="{{ section.id }}">
  <div class="oh-marquee-track-{{ section.id }}">
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        <div class="oh-marquee-item-{{ section.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_svg != blank -%}
            <div class="oh-marquee-icon-{{ section.id }}">
              {{ block.settings.icon_svg }}
            </div>
          {%- elsif block.settings.icon_image != blank -%}
             <div class="oh-marquee-icon-{{ section.id }}">
               {{ block.settings.icon_image | image_url: width: 120 | image_tag: loading: 'lazy' }}
             </div>
          {%- endif -%}
          <div class="oh-text-group-{{ section.id }}">
            {%- if block.settings.text != blank -%}
              <span class="oh-marquee-text-{{ section.id }}">{{ block.settings.text }}</span>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <span class="oh-marquee-sub-{{ section.id }}">{{ block.settings.subtext }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Custom Marquee",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "sub_text_color",
      "label": "Subtext Color",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Scroll Speed (seconds)",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "sub_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Sub Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Icon Size",
      "default": 56
    },
    {
      "type": "range",
      "id": "item_margin",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Item Spacing",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG Code",
          "info": "Paste SVG code here or select an image below."
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Main Text",
          "default": "FDA Approved"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Certified Safe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Marquee",
      "blocks": [
        { "type": "marquee_item" },
        { "type": "marquee_item" },
        { "type": "marquee_item" }
      ]
    }
  ]
}
{% endschema %}
