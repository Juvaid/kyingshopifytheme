{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .tabbed-collection__header {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
  }

  .tabbed-collection__tab {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 2.2rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #CCCCCC;
    letter-spacing: 0.12em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: var(--font-heading-family);
    position: relative;
  }

  .tabbed-collection__tab:hover {
    color: #666666;
  }

  .tabbed-collection__tab.active {
    color: #000000;
  }

  .tabbed-collection__separator {
    color: #EEEEEE;
    font-size: 2rem;
    font-weight: 300;
    user-select: none;
  }

  .tabbed-collection__content {
    display: none;
  }

  .tabbed-collection__content.active {
    display: block;
    animation: tabFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes tabFadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Grid refinement */
  .tabbed-collection .grid {
    column-gap: var(--grid-desktop-horizontal-spacing);
    row-gap: var(--grid-desktop-vertical-spacing);
  }

  /* Responsive adjustments */
  @media screen and (max-width: 749px) {
    .tabbed-collection__header {
      gap: 1.2rem;
      margin-bottom: 2.5rem;
    }
    .tabbed-collection__tab {
      font-size: 1.6rem;
    }
    .tabbed-collection__separator {
      font-size: 1.4rem;
    }
    .tabbed-collection .product-grid {
      column-gap: var(--grid-mobile-horizontal-spacing);
      row-gap: var(--grid-mobile-vertical-spacing);
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="section-{{ section.id }}-padding page-width">
    {%- if section.settings.title != blank -%}
      <div class="center" style="margin-bottom: 2rem;">
         <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    <tabbed-collection class="tabbed-collection">
      <div class="tabbed-collection__header" role="tablist">
        {%- for block in section.blocks -%}
          {%- if forloop.index0 > 0 -%}
            <span class="tabbed-collection__separator" aria-hidden="true">|</span>
          {%- endif -%}
          <button
            type="button"
            class="tabbed-collection__tab{% if forloop.first %} active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="TabPanel-{{ section.id }}-{{ forloop.index }}"
            id="Tab-{{ section.id }}-{{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_title | default: block.settings.collection.title | default: 'Collection' }}
          </button>
        {%- endfor -%}
      </div>

      <div class="tabbed-collection__panels">
        {%- for block in section.blocks -%}
          <div
            class="tabbed-collection__content{% if forloop.first %} active{% endif %}"
            id="TabPanel-{{ section.id }}-{{ forloop.index }}"
            role="tabpanel"
            aria-labelledby="Tab-{{ section.id }}-{{ forloop.index }}"
            {% unless forloop.first %}hidden{% endunless %}
          >
            <ul class="grid product-grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down" role="list">
              {%- if block.settings.collection != blank -%}
                {%- for product in block.settings.collection.products limit: section.settings.products_to_show -%}
                  <li class="grid__item">
                    {% render 'component-product-card',
                      product: product,
                      show_rating: section.settings.show_rating,
                      show_quick_add: true,
                      section_id: section.id
                    %}
                  </li>
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..section.settings.products_to_show) -%}
                  <li class="grid__item">
                    {%- assign placeholder_image = 'product-apparel-' | append: forloop.index -%}
                    {% render 'component-product-card',
                      placeholder_image: placeholder_image
                    %}
                  </li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endfor -%}
      </div>
    </tabbed-collection>
  </div>
</div>

<script>
  if (!customElements.get('tabbed-collection')) {
    customElements.define('tabbed-collection', class TabbedCollection extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('[role="tab"]');
        this.panels = this.querySelectorAll('[role="tabpanel"]');
        
        this.tabs.forEach(tab => {
          tab.addEventListener('click', (e) => this.onTabClick(e));
        });
      }

      onTabClick(event) {
        const target = event.currentTarget;
        const index = target.dataset.index;

        // Update tabs
        this.tabs.forEach(tab => {
          tab.classList.remove('active');
          tab.setAttribute('aria-selected', 'false');
        });
        target.classList.add('active');
        target.setAttribute('aria-selected', 'true');

        // Update panels
        this.panels.forEach((panel, i) => {
          if (i == index) {
            panel.classList.add('active');
            panel.removeAttribute('hidden');
          } else {
            panel.classList.remove('active');
            panel.setAttribute('hidden', '');
          }
        });

        // Trigger scroll-trigger animations if any
        if (window.Shopify && window.Shopify.designMode) {
          // In editor, we might need to refresh
        }
      }
    });
  }
</script>

{% schema %}
{
  "name": "Tabbed Collection",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title (Optional)"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show per tab"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Tab",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabbed Collection",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
