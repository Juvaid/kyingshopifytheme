{%- render 'cart-drawer', settings: section.settings -%}

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "header",
      "content": "Product Name Truncation"
    },
    {
      "type": "checkbox",
      "id": "truncate_cart_product_names",
      "label": "Truncate long product names",
      "default": true,
      "info": "Helps save space on mobile by shortening long titles."
    },
    {
      "type": "range",
      "id": "cart_product_name_limit",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "ch",
      "label": "Character limit",
      "default": 35
    },
    {
      "type": "header",
      "content": "Empty Cart Featured Collection"
    },
    {
      "type": "collection",
      "id": "empty_cart_collection",
      "label": "Featured collection",
      "info": "Shown when the cart is empty."
    },
    {
      "type": "text",
      "id": "empty_cart_heading",
      "label": "Heading",
      "default": "Top Collections For You"
    },
    {
      "type": "range",
      "id": "empty_cart_collection_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns on desktop",
      "default": 1
    },
    {
      "type": "header",
      "content": "Upsell & Promo Code"
    },
    {
      "type": "collection",
      "id": "cart_drawer_upsell_collection",
      "label": "Cart drawer upsell collection",
      "info": "Products to show in the 'You might also like' section."
    },
    {
      "type": "text",
      "id": "cart_drawer_upsell_heading",
      "label": "Upsell heading",
      "default": "You might also like"
    },
    {
      "type": "header",
      "content": "Free Shipping Progress Bar"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping_bar",
      "label": "Show free shipping progress bar",
      "default": true
    },
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold",
      "info": "Enter the amount without currency symbols (e.g. 1000).",
      "default": 1000
    },
    {
      "type": "text",
      "id": "free_shipping_message",
      "label": "Progress message",
      "info": "Use [amount] to show the remaining amount.",
      "default": "You're only [amount] away from free shipping!"
    },
    {
      "type": "text",
      "id": "free_shipping_success_message",
      "label": "Success message",
      "default": "Congratulations! You've unlocked free shipping."
    },
    {
      "type": "checkbox",
      "id": "show_discount_code",
      "label": "Show discount code field",
      "default": true
    }
  ]
}
{% endschema %}
