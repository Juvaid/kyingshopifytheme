{%- render 'cart-drawer', settings: section.settings -%}

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "header",
      "content": "Product Name Truncation"
    },
    {
      "type": "checkbox",
      "id": "truncate_cart_product_names",
      "label": "Truncate long product names",
      "default": true,
      "info": "Helps save space on mobile by shortening long titles."
    },
    {
      "type": "range",
      "id": "cart_product_name_limit",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "ch",
      "label": "Character limit",
      "default": 35
    },
    {
      "type": "header",
      "content": "Upsell & Promo Code"
    },
    {
      "type": "collection",
      "id": "cart_drawer_upsell_collection",
      "label": "Cart drawer upsell collection",
      "info": "Products to show in the 'You might also like' section."
    },
    {
      "type": "text",
      "id": "cart_drawer_upsell_heading",
      "label": "Upsell heading",
      "default": "You might also like"
    },
    {
      "type": "checkbox",
      "id": "show_discount_code",
      "label": "Show discount code field",
      "default": true
    }
  ]
}
{% endschema %}
