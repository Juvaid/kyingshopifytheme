{%- render 'cart-drawer', drawer_settings: section.settings -%}

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "header",
      "content": "Product Name Truncation"
    },
    {
      "type": "checkbox",
      "id": "truncate_cart_product_names",
      "label": "Truncate long product names",
      "default": true,
      "info": "Helps save space on mobile by shortening long titles."
    },
    {
      "type": "range",
      "id": "cart_product_name_limit",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "ch",
      "label": "Character limit",
      "default": 35
    },
    {
      "type": "header",
      "content": "Empty Cart Featured Collection"
    },
    {
      "type": "collection",
      "id": "empty_cart_collection",
      "label": "Featured collection",
      "info": "Shown when the cart is empty."
    },
    {
      "type": "text",
      "id": "empty_cart_heading",
      "label": "Heading",
      "default": "Top Collections For You"
    },
    {
      "type": "range",
      "id": "empty_cart_collection_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns on desktop",
      "default": 1
    }
  ]
}
{% endschema %}
